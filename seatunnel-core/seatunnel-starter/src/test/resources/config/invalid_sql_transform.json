{
  "env": {
    "parallelism": 1,
    "job.mode": "BATCH"
  },
  "source": [
    {
      "plugin_name": "FakeSource",
      "plugin_output": "fake",
      "schema": {
        "fields": {
          "id": "int",
          "name": "string"
        }
      }
    }
  ],
  "transform": [
    {
      "plugin_name": "Sql",
      "plugin_input": "fake",
      "plugin_output": "sql_out",
      "query": "SELCT * FROM fake WHERE id > 1"
    }
  ],
  "sink": [
    {
      "plugin_name": "Console",
      "plugin_input": "sql_out"
    }
  ]
}